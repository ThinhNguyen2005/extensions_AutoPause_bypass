{
  "manifest_version": 3,
  "name": "YT Pro Enhancer - SponsorBlock & Auto-Pause",
  "version": "1.0",
  "description": "Tiện ích mở rộng chặn tự động dừng video, tự động bỏ qua quảng cáo tài trợ (SponsorBlock) và quảng cáo truyền thống trên YouTube.",
  "permissions": [
    "activeTab"
  ],
  "action": {
    "default_title": "Kích hoạt YT Pro Enhancer",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
